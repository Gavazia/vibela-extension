{
  "name": "vibela-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Vibela browser extension shell.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test:unit": "vitest run",
    "pretest": "npm run build",
    "test": "playwright test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "@wxt-dev/module-react": "1.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "wxt": "0.20.26"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/chrome": "0.1.42",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "sharp": "^0.34.5",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
